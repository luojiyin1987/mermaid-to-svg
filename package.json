{
  "name": "mermaid-to-svg",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/app.js --bundle --minify --format=iife --platform=browser --target=es2020 --outfile=public/app.js",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "wrangler": "^4.86.0"
  }
}
